{
  "name": "@edda/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "eval": "vitest run --config evals/vitest.config.ts",
    "eval:watch": "vitest watch --config evals/vitest.config.ts",
    "eval:capture": "vitest run --config evals/vitest.config.ts evals/capture/",
    "eval:ci": "vitest run --config evals/vitest.config.ts"
  },
  "dependencies": {
    "@edda/db": "workspace:*",
    "deepagents": "^1.7.0",
    "@langchain/core": "^1.1.0",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/openai": "^0.4.0",
    "@langchain/google-genai": "^0.2.0",
    "@langchain/community": "^0.3.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/langgraph-checkpoint-postgres": "^0.1.0",
    "node-cron": "^3.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^2.0.0",
    "agentevals": "^0.1.0",
    "openevals": "^0.1.0",
    "langsmith": "^0.3.0",
    "@types/node-cron": "^3.0.0"
  }
}
