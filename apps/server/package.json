{
  "name": "@edda/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config vitest.config.ts",
    "eval": "vitest run --config evals/vitest.config.ts",
    "eval:watch": "vitest watch --config evals/vitest.config.ts",
    "eval:capture": "vitest run --config evals/vitest.config.ts evals/capture/",
    "eval:ci": "vitest run --config evals/vitest.config.ts"
  },
  "dependencies": {
    "@edda/db": "workspace:*",
    "@langchain/anthropic": "^1.3.19",
    "@langchain/community": "^1.1.17",
    "@langchain/core": "^1.1.27",
    "@langchain/google-genai": "^2.1.20",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.2.9",
    "async-mutex": "^0.5.0",
    "deepagents": "^1.7.0",
    "duck-duck-scrape": "^2.2.7",
    "node-cron": "^3.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^2.0.0",
    "@types/node-cron": "^3.0.0",
    "agentevals": "^0.0.6",
    "langsmith": "^0.3.0",
    "openevals": "^0.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^2.0.0"
  }
}
