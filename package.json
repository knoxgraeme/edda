{
  "name": "edda",
  "private": true,
  "description": "AI personal assistant — your second brain",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "turbo": "^2.8.1"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "migrate": "pnpm --filter @edda/db migrate",
    "db:seed-settings": "pnpm --filter @edda/db seed-settings",
    "eval": "pnpm --filter @edda/server eval",
    "eval:ci": "pnpm --filter @edda/server eval:ci",
    "init": "pnpm --filter @edda/cli init"
  }
}
