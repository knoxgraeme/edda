{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "eval": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "eval:ci": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
