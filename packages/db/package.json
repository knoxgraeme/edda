{
  "name": "@edda/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types.js",
    "./migrations": "./dist/migrate.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "migrate": "tsx --env-file=../../.env src/migrate.ts",
    "seed-settings": "tsx --env-file=../../.env src/seed-settings.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "pg": "^8.13.0",
    "pgvector": "^0.2.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.9.0",
    "vitest": "^2.0.0"
  }
}
