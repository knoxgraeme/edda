{
  "$schema": "https://railway.app/railway-template.schema.json",
  "name": "Edda",
  "description": "Personal AI assistant — second brain with LangGraph, Postgres/pgvector, and Claude",
  "icon": "🧠",
  "services": [
    {
      "name": "edda-server",
      "source": {
        "repo": "https://github.com/YOUR_ORG/edda"
      },
      "buildConfig": {
        "dockerfilePath": "Dockerfile",
        "target": "server"
      },
      "deploy": {
        "startCommand": "node packages/db/dist/migrate.js && node apps/server/dist/index.js",
        "healthcheckPath": "/health"
      },
      "variables": {
        "DATABASE_URL": { "reference": "postgres.DATABASE_URL" },
        "ANTHROPIC_API_KEY": { "description": "Your Anthropic API key", "required": true },
        "LLM_PROVIDER": { "default": "anthropic" },
        "LLM_MODEL": { "default": "claude-sonnet-4-20250514" },
        "EMBEDDING_PROVIDER": { "default": "voyage" },
        "VOYAGE_API_KEY": { "description": "Your Voyage AI API key", "required": true },
        "CRON_RUNNER": { "default": "standalone" },
        "CHECKPOINTER_BACKEND": { "default": "postgres" },
        "NODE_ENV": { "default": "production" },
        "PORT": { "default": "8000" }
      }
    },
    {
      "name": "edda-web",
      "source": {
        "repo": "https://github.com/YOUR_ORG/edda"
      },
      "buildConfig": {
        "dockerfilePath": "Dockerfile",
        "target": "web"
      },
      "variables": {
        "NEXT_PUBLIC_API_URL": { "reference": "edda-server.RAILWAY_PUBLIC_DOMAIN" },
        "PORT": { "default": "3000" }
      }
    },
    {
      "name": "postgres",
      "plugin": "postgresql",
      "pluginConfig": {
        "extensions": ["pgvector"]
      }
    }
  ]
}
