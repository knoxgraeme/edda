# ─── Edda Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in your values.
# Or run `npx edda init` for an interactive setup wizard.

# ─── Database ───────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/edda"

# ─── Provider API Keys ─────────────────────────────────────────────
# LLM provider and model are configured in the web UI settings page.
# Set the API key(s) for whichever provider(s) you plan to use.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=

# ─── Embeddings ─────────────────────────────────────────────────────
# Embedding provider is configured in the web UI settings page.
VOYAGEAI_API_KEY=

# ─── Web Search (optional) ─────────────────────────────────────────
# Options: tavily, brave, serper, serpapi
# SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=
# BRAVE_API_KEY=
# SERPER_API_KEY=
# SERPAPI_API_KEY=

# ─── Community Tools (optional) ───────────────────────────────────
# Wikipedia and DuckDuckGo are available with no API key.
# WolframAlpha requires a free App ID from https://developer.wolframalpha.com
# WOLFRAM_APP_ID=

# ─── LangSmith (optional) ─────────────────────────────────────────
# Set these to enable tracing and eval reporting
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=edda

# ─── MCP Authentication ─────────────────────────────────────────────
# For each MCP server, set a long-lived API key as an env var and reference it by name in Edda.
# The DB stores only the env var name — the actual token stays in your environment.
# IMPORTANT: Env var names MUST start with MCP_AUTH_ (e.g. MCP_AUTH_MYSERVICE_TOKEN).
# This prefix requirement prevents accidental exfiltration of unrelated secrets.
# MCP_AUTH_MYSERVICE_TOKEN=your-token-here

# ─── Auth (optional) ──────────────────────────────────────────────
# Set a password to protect the web UI when deployed publicly.
# Leave empty to disable authentication (e.g. local development).
# EDDA_PASSWORD=

# ─── Filesystem Access (optional) ─────────────────────────────────
# Enable per-agent filesystem access for self-hosted deployments.
# Both vars must be set. Agents declare a relative subdirectory in metadata.
# ALLOW_FILESYSTEM_ACCESS=true
# FILESYSTEM_ROOT=/data

# ─── Internal API Auth (required) ──────────────────────────────────
# Shared secret for authenticating requests to the backend server (port 8000).
# All endpoints (except /api/health and channel webhooks) require: Authorization: Bearer <secret>
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# ─── Channel Integrations (optional) ─────────────────────────────
# Telegram — webhook-based bot. Requires TELEGRAM_WEBHOOK_SECRET.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/channels/telegram/webhook

# Discord — Gateway WebSocket bot. Create at https://discord.com/developers
# DISCORD_BOT_TOKEN=

# Slack — Socket Mode bot. Create at https://api.slack.com/apps
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ─── CORS (optional) ─────────────────────────────────────────────
# Allowed origin for the backend server. Defaults to http://localhost:3000.
# CORS_ORIGIN=http://localhost:3000

# ─── Deployment Networking ────────────────────────────────────────
# URL the web frontend (and the cron-client) uses to reach the backend
# server. The cron-client reads SERVER_URL to build the /api/cron/tick
# URL when running as an external scheduler (e.g. Railway Cron Jobs).
# Local dev: http://localhost:8000 (default)
# Fly.io: http://<app-name>.internal:8000
# Railway: https://<server-service>.up.railway.app
# SERVER_URL=http://localhost:8000

# Base URL for the web frontend (used for CORS, OAuth callbacks, etc.)
# EDDA_BASE_URL=https://your-app.fly.dev

# ─── Server ────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Scheduling (optional) ────────────────────────────────────────
# The cron runner mode lives in the `settings` DB table, not here.
# Two modes:
#   in_process   — node-cron inside the server process (default).
#                  Best for local dev, VPS, single-instance Fly/Render.
#   http_trigger — external scheduler pokes POST /api/cron/tick.
#                  Unlocks scale-to-zero on Railway Cron Jobs, pg_cron,
#                  GitHub Actions, etc. See README "Scheduling
#                  architecture" for setup.
